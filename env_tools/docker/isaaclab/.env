###
# General settings
###

# Base dir for this project; scripts/start.sh exports BASE_DIR automatically.
# ${BASE_DIR}

ACCEPT_EULA=Y

# Isaac Sim image
ISAACSIM_BASE_IMAGE=nvcr.io/nvidia/isaac-sim
ISAACSIM_VERSION=5.1.0

# Isaac Lab source/version used by scripts/init.sh
ISAACLAB_VERSION=v2.3.2
ISAACLAB_REPO=https://github.com/isaac-sim/IsaacLab.git

# Container paths
DOCKER_ISAACSIM_ROOT_PATH=/isaac-sim
DOCKER_ISAACLAB_PATH=/workspace/isaaclab
DOCKER_USER_HOME=/root

# Host project root
PROJECT_ROOT=${BASE_DIR}
